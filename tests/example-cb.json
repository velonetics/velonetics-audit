{
  "$schema": "https://pucora.io/schema/pucora.json",
  "version": 3,
  "host": ["http://localhost:8080"],
  "echo_endpoint": true,
  "debug_endpoint": true,
  "endpoints": [
    {
      "endpoint": "/",
      "backend": [
        {
          "url_pattern": "/__echo/",
          "extra_config": {
            "qos/circuit-breaker/http": {
              "interval": 0,
              "max_errors": 5,
              "timeout": 10,
              "valid_status_codes": [
                200,
                201,
                404
              ]
            }
          }
        }
      ]
    }
  ]
}